# Rust build output. Cargo.lock is deliberately NOT ignored: this workspace
# builds shipped binaries (and a staticlib Xcode links), so pinning the exact
# dependency set is the point.
/target/

# Generated by xcodegen from macos/project.yml — that file is the source of
# truth, and `cd macos && xcodegen` rewrites all three. Editing them by hand (or
# committing them) only creates something to be silently overwritten.
/macos/BetterAC.xcodeproj/
/macos/Info.plist
/macos/BetterAC.entitlements

# Xcode per-user state and in-tree build output.
xcuserdata/
*.xcuserdatad/
DerivedData/
*.xcscmblueprint
*.xccheckout

# macOS
.DS_Store

# NOT ignored on purpose:
#   ffi/include/ac_ffi.h  — cbindgen regenerates it every build, but a failure
#     there is only a warning, so a fresh clone that couldn't run cbindgen would
#     otherwise fail to build with a confusing missing-header error. Tracking it
#     also makes ABI changes show up in review, which is where they matter.
#   gtk/dist/             — the drop point for the prebuilt Linux binary that
#     gtk/install.sh installs on Bazzite (an atomic distro with no host
#     compiler). That binary is a shipped artifact, not local build output.
